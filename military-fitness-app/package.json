{
  "name": "military-fitness-hub",
  "version": "0.1.0",
  "private": true,
  "description": "A PWA-ready military fitness tracking app with Capacitor packaging support.",
  "scripts": {
    "serve": "npx http-server . -p 8080",
    "install:capacitor": "npx cap init 'Military Fitness Hub' 'com.example.militaryfitness' --web-dir .",
    "cap:copy": "npx cap copy",
    "cap:add-android": "npx cap add android",
    "cap:add-ios": "npx cap add ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "http-server": "^14.1.1"
  }
}
